# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (get via: https://api.telegram.org/bot<TOKEN>/getUpdates after messaging the bot)
TELEGRAM_CHAT_ID=

# Shared secret required on every hook request. Generate with:
#   openssl rand -hex 32
# Must be at least 16 characters. Keep this secret — anyone with it can
# spoof approval responses to local agents.
SHIRO_SHARED_SECRET=

# Port for the local HTTP server that agent hooks POST to
HTTP_PORT=7777
